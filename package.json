{
  "name": "playwright-interview",
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.9.2",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.6.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:clean": "node --input-type=module -e \"import { existsSync, rmSync } from 'node:fs'; for (const dir of ['reports/allure-results', 'reports/allure-report']) { if (existsSync(dir)) rmSync(dir, { recursive: true, force: true }); }\"",
    "allure:clean:report": "node --input-type=module -e \"import { existsSync, rmSync } from 'node:fs'; const dir = 'reports/allure-report'; if (existsSync(dir)) rmSync(dir, { recursive: true, force: true });\"",
    "allure:latest": "npm run allure:clean:report && npm run allure:serve",
    "allure:run": "node reports/scripts/run-cucumber-allure.mjs",
    "test:cucumber": "cucumber-js --config cucumber.mjs",
    "test:cucumber:smoke": "cucumber-js --config cucumber.mjs --tags \"@smoke\" --retry 1",
    "test:cucumber:smoke:summary": "cucumber-js --config cucumber.mjs --tags \"@smoke\" --retry 1 --format progress --format summary --format allure-cucumberjs/reporter",
    "test:cucumber:smoke:allure": "npm run allure:run -- test:cucumber:smoke:summary",
    "test:cucumber:THISONE": "cucumber-js --config cucumber.mjs --tags \"@THISONE\"",
    "test:cucumber:THISONE:slow": "set SLOW_MO_MS=1000&& cucumber-js --config cucumber.mjs --tags \"@THISONE\"",
    "test:cucumber:regression": "cucumber-js --config cucumber.mjs --tags \"@regression\" --retry 1",
    "test:cucumber:regression:summary": "cucumber-js --config cucumber.mjs --tags \"@regression\" --retry 1 --format progress --format summary --format allure-cucumberjs/reporter",
    "test:cucumber:regression:allure": "npm run allure:run -- test:cucumber:regression:summary",
    "test:cucumber:auth": "cucumber-js --config cucumber.mjs tests/features/authentication.feature",
    "test:cucumber:auth:slow": "set SLOW_MO_MS=1000&& cucumber-js --config cucumber.mjs tests/features/authentication.feature",
    "test:cucumber:checkout": "cucumber-js --config cucumber.mjs tests/features/checkout.feature",
    "test:cucumber:cart": "cucumber-js --config cucumber.mjs tests/features/add-items-to-cart.feature",
    "test:cucumber:modals": "cucumber-js --config cucumber.mjs tests/features/site-modals.feature",
    "test:cucumber:tag": "cucumber-js --config cucumber.mjs --tags",
    "test:cucumber:allure": "cucumber-js --config cucumber.mjs",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:serve": "allure serve reports/allure-results"
  }
}
